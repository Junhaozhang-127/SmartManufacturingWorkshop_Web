# Shared
NODE_ENV=development
APP_NAME=Smart Manufacturing Workshop Lab System
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
API_PREFIX=api
WEB_PORT=5173
VITE_APP_TITLE=Lab Management System
VITE_API_BASE_URL=http://localhost:3000/api

# Database
DATABASE_URL=mysql://<user>:<password>@127.0.0.1:3306/<database>

# Redis reserved
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# MinIO reserved
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=smw-lab-dev

# Security
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_DISPLAY_NAME=
SEED_ADMIN_FORCE_PASSWORD_CHANGE=true
AUTH_TOKEN_SECRET=CHANGE_ME__MIN_32_CHARS
AUTH_TOKEN_TTL_SECONDS=28800
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
HEALTH_EXPOSE_DETAILS=false
