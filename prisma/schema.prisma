generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SysUser {
  id           BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  username     String          @unique @db.VarChar(64)
  passwordHash String          @map("password_hash") @db.VarChar(255)
  displayName  String          @map("display_name") @db.VarChar(64)
  mobile       String?         @db.VarChar(20)
  email        String?         @db.VarChar(128)
  statusCode   String          @default("ACTIVE") @map("status_code") @db.VarChar(20)
  forcePasswordChange Boolean  @default(true) @map("force_password_change")
  lastLoginAt  DateTime?       @map("last_login_at")
  passwordChangedAt DateTime?  @map("password_changed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  createdBy    BigInt?         @map("created_by") @db.UnsignedBigInt
  isDeleted    Boolean         @default(false) @map("is_deleted")
  userRoles    SysUserRole[]
  member       MemberProfile?
  ledOrgUnits  OrgUnit[]       @relation("OrgUnitLeader")
  mentorFor    MemberProfile[] @relation("MemberMentor")
  memberGrowthRecords      MemberGrowthRecord[]      @relation("MemberGrowthActor")
  memberStageEvaluations   MemberStageEvaluation[]   @relation("MemberStageEvaluator")
  memberRegularizations    MemberRegularization[]    @relation("MemberRegularizationApplicant")
  memberOperationLogs      MemberOperationLog[]      @relation("MemberOperationActor")
  approvalInstancesStarted  WfApprovalInstance[] @relation("ApprovalApplicant")
  approvalInstancesAssigned WfApprovalInstance[] @relation("ApprovalCurrentAssignee")
  approvalLogs              WfApprovalNodeLog[]  @relation("ApprovalActor")
  approvalTransferTargets   WfApprovalNodeLog[]  @relation("ApprovalTransferTarget")
  demoApprovalForms         DemoApprovalForm[]   @relation("DemoApprovalApplicant")

  @@map("sys_user")
}

model SysRole {
  id         BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  roleCode   String        @unique @map("role_code") @db.VarChar(32)
  roleName   String        @map("role_name") @db.VarChar(64)
  dataScope  String        @map("data_scope") @db.VarChar(20)
  sortNo     Int?          @map("sort_no")
  statusCode String        @default("ACTIVE") @map("status_code") @db.VarChar(20)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  userRoles  SysUserRole[]

  @@map("sys_role")
}

model SysUserRole {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId        BigInt    @map("user_id") @db.UnsignedBigInt
  roleId        BigInt    @map("role_id") @db.UnsignedBigInt
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  role          SysRole   @relation(fields: [roleId], references: [id])
  user          SysUser   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
  @@map("sys_user_role")
}

model OrgUnit {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  parentId       BigInt?         @map("parent_id") @db.UnsignedBigInt
  unitCode       String          @unique @map("unit_code") @db.VarChar(32)
  unitName       String          @map("unit_name") @db.VarChar(128)
  unitType       String          @map("unit_type") @db.VarChar(32)
  leaderUserId   BigInt?         @map("leader_user_id") @db.UnsignedBigInt
  statusCode     String          @default("ACTIVE") @map("status_code") @db.VarChar(20)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  createdBy      BigInt?         @map("created_by") @db.UnsignedBigInt
  isDeleted      Boolean         @default(false) @map("is_deleted")
  children       OrgUnit[]       @relation("OrgUnitTree")
  leader         SysUser?        @relation("OrgUnitLeader", fields: [leaderUserId], references: [id])
  memberProfiles MemberProfile[]
  parent         OrgUnit?        @relation("OrgUnitTree", fields: [parentId], references: [id])

  @@index([parentId])
  @@map("org_unit")
}

model MemberProfile {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt   @unique @map("user_id") @db.UnsignedBigInt
  orgUnitId    BigInt   @map("org_unit_id") @db.UnsignedBigInt
  positionCode String   @map("position_code") @db.VarChar(32)
  mentorUserId BigInt?  @map("mentor_user_id") @db.UnsignedBigInt
  joinDate     DateTime @map("join_date") @db.Date
  memberStatus String   @map("member_status") @db.VarChar(20)
  skillTags    String?  @map("skill_tags") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    BigInt?  @map("created_by") @db.UnsignedBigInt
  isDeleted    Boolean  @default(false) @map("is_deleted")
  mentor       SysUser? @relation("MemberMentor", fields: [mentorUserId], references: [id])
  orgUnit      OrgUnit  @relation(fields: [orgUnitId], references: [id])
  user         SysUser  @relation(fields: [userId], references: [id])
  growthRecords MemberGrowthRecord[]
  stageEvaluations MemberStageEvaluation[]
  regularizations MemberRegularization[]
  operationLogs MemberOperationLog[]

  @@index([orgUnitId])
  @@map("member_profile")
}

model MemberGrowthRecord {
  id              BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  memberProfileId BigInt        @map("member_profile_id") @db.UnsignedBigInt
  recordType      String        @map("record_type") @db.VarChar(32)
  title           String        @db.VarChar(128)
  content         String?       @db.VarChar(1000)
  recordDate      DateTime      @map("record_date") @db.Date
  actorUserId     BigInt?       @map("actor_user_id") @db.UnsignedBigInt
  extraData       Json?         @map("extra_data")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  actor           SysUser?      @relation("MemberGrowthActor", fields: [actorUserId], references: [id])
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id])

  @@index([memberProfileId, recordDate])
  @@map("member_growth_record")
}

model MemberStageEvaluation {
  id                BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  memberProfileId   BigInt        @map("member_profile_id") @db.UnsignedBigInt
  stageCode         String        @map("stage_code") @db.VarChar(32)
  summary           String        @db.VarChar(500)
  score             Int?
  resultCode        String        @map("result_code") @db.VarChar(32)
  nextAction        String?       @map("next_action") @db.VarChar(500)
  evaluatedAt       DateTime      @map("evaluated_at")
  evaluatorUserId   BigInt        @map("evaluator_user_id") @db.UnsignedBigInt
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  evaluator         SysUser       @relation("MemberStageEvaluator", fields: [evaluatorUserId], references: [id])
  memberProfile     MemberProfile @relation(fields: [memberProfileId], references: [id])

  @@index([memberProfileId, evaluatedAt])
  @@map("member_stage_evaluation")
}

model MemberRegularization {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  memberProfileId     BigInt              @map("member_profile_id") @db.UnsignedBigInt
  applicantUserId     BigInt              @map("applicant_user_id") @db.UnsignedBigInt
  statusCode          String              @default("DRAFT") @map("status_code") @db.VarChar(32)
  internshipStartDate DateTime            @map("internship_start_date") @db.Date
  plannedRegularDate  DateTime            @map("planned_regular_date") @db.Date
  applicationReason   String              @map("application_reason") @db.VarChar(1000)
  selfAssessment      String?             @map("self_assessment") @db.VarChar(1000)
  mentorUserId        BigInt?             @map("mentor_user_id") @db.UnsignedBigInt
  approvalInstanceId  BigInt?             @unique @map("approval_instance_id") @db.UnsignedBigInt
  submittedAt         DateTime?           @map("submitted_at")
  completedAt         DateTime?           @map("completed_at")
  latestResult        String?             @map("latest_result") @db.VarChar(500)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  applicant           SysUser             @relation("MemberRegularizationApplicant", fields: [applicantUserId], references: [id])
  memberProfile       MemberProfile       @relation(fields: [memberProfileId], references: [id])
  approvalInstance    WfApprovalInstance? @relation(fields: [approvalInstanceId], references: [id])

  @@index([memberProfileId, statusCode])
  @@index([applicantUserId, statusCode])
  @@map("member_regularization")
}

model MemberOperationLog {
  id              BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  memberProfileId BigInt        @map("member_profile_id") @db.UnsignedBigInt
  actionType      String        @map("action_type") @db.VarChar(32)
  fromStatus      String?       @map("from_status") @db.VarChar(32)
  toStatus        String?       @map("to_status") @db.VarChar(32)
  description     String        @db.VarChar(500)
  operatorUserId  BigInt?       @map("operator_user_id") @db.UnsignedBigInt
  extraData       Json?         @map("extra_data")
  createdAt       DateTime      @default(now()) @map("created_at")
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id])
  operator        SysUser?      @relation("MemberOperationActor", fields: [operatorUserId], references: [id])

  @@index([memberProfileId, createdAt])
  @@map("member_operation_log")
}

model WfApprovalTemplate {
  id           BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  templateCode String                   @unique @map("template_code") @db.VarChar(64)
  templateName String                   @map("template_name") @db.VarChar(128)
  businessType String                   @unique @map("business_type") @db.VarChar(64)
  statusCode   String                   @default("ACTIVE") @map("status_code") @db.VarChar(20)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  nodes        WfApprovalTemplateNode[]
  instances    WfApprovalInstance[]

  @@map("wf_approval_template")
}

model WfApprovalTemplateNode {
  id               BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  templateId       BigInt             @map("template_id") @db.UnsignedBigInt
  nodeKey          String             @map("node_key") @db.VarChar(64)
  nodeName         String             @map("node_name") @db.VarChar(128)
  sortNo           Int                @map("sort_no")
  approverRoleCode String             @map("approver_role_code") @db.VarChar(32)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  template         WfApprovalTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, nodeKey])
  @@unique([templateId, sortNo])
  @@index([templateId, sortNo])
  @@map("wf_approval_template_node")
}

model WfApprovalInstance {
  id                      BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  templateId              BigInt?             @map("template_id") @db.UnsignedBigInt
  businessType            String              @map("business_type") @db.VarChar(64)
  businessId              String              @map("business_id") @db.VarChar(64)
  title                   String              @db.VarChar(255)
  status                  String              @default("PENDING") @db.VarChar(20)
  applicantUserId         BigInt              @map("applicant_user_id") @db.UnsignedBigInt
  applicantRoleCode       String?             @map("applicant_role_code") @db.VarChar(32)
  currentNodeKey          String?             @map("current_node_key") @db.VarChar(64)
  currentNodeName         String?             @map("current_node_name") @db.VarChar(128)
  currentNodeSort         Int?                @map("current_node_sort")
  currentApproverRoleCode String?             @map("current_approver_role_code") @db.VarChar(32)
  currentApproverUserId   BigInt?             @map("current_approver_user_id") @db.UnsignedBigInt
  latestComment           String?             @map("latest_comment") @db.VarChar(500)
  formData                Json?               @map("form_data")
  finishedAt              DateTime?           @map("finished_at")
  withdrawnAt             DateTime?           @map("withdrawn_at")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  applicant               SysUser             @relation("ApprovalApplicant", fields: [applicantUserId], references: [id])
  currentApprover         SysUser?            @relation("ApprovalCurrentAssignee", fields: [currentApproverUserId], references: [id])
  template                WfApprovalTemplate? @relation(fields: [templateId], references: [id])
  logs                    WfApprovalNodeLog[]
  demoForm                DemoApprovalForm?
  memberRegularization    MemberRegularization?

  @@index([businessType, businessId])
  @@index([status, currentApproverRoleCode])
  @@index([status, currentApproverUserId])
  @@index([applicantUserId, status])
  @@map("wf_approval_instance")
}

model WfApprovalNodeLog {
  id           BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  instanceId   BigInt              @map("instance_id") @db.UnsignedBigInt
  nodeKey      String?             @map("node_key") @db.VarChar(64)
  nodeName     String?             @map("node_name") @db.VarChar(128)
  actionType   String              @map("action_type") @db.VarChar(32)
  actorUserId  BigInt              @map("actor_user_id") @db.UnsignedBigInt
  actorRoleCode String?            @map("actor_role_code") @db.VarChar(32)
  targetUserId BigInt?             @map("target_user_id") @db.UnsignedBigInt
  comment      String?             @db.VarChar(500)
  extraData    Json?               @map("extra_data")
  createdAt    DateTime            @default(now()) @map("created_at")
  actor        SysUser             @relation("ApprovalActor", fields: [actorUserId], references: [id])
  instance     WfApprovalInstance  @relation(fields: [instanceId], references: [id])
  targetUser   SysUser?            @relation("ApprovalTransferTarget", fields: [targetUserId], references: [id])

  @@index([instanceId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("wf_approval_node_log")
}

model DemoApprovalForm {
  id                 BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  title              String              @db.VarChar(128)
  reason             String              @db.VarChar(500)
  statusCode         String              @default("DRAFT") @map("status_code") @db.VarChar(20)
  applicantUserId    BigInt              @map("applicant_user_id") @db.UnsignedBigInt
  approvalInstanceId BigInt?             @unique @map("approval_instance_id") @db.UnsignedBigInt
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  applicant          SysUser             @relation("DemoApprovalApplicant", fields: [applicantUserId], references: [id])
  approvalInstance   WfApprovalInstance? @relation(fields: [approvalInstanceId], references: [id])

  @@index([applicantUserId, statusCode])
  @@map("demo_approval_form")
}
